# Investigator Agent Service
# Heavy on LLM token throughput (multi-step ReAct: parse → read → grep → git_log)
# Scale trigger: Memory (LLM context) > 65%, CPU > 70%
FROM python:3.11-slim AS builder
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends build-essential git && rm -rf /var/lib/apt/lists/*
COPY requirements.txt .
RUN pip install --upgrade pip && pip install --prefix=/install --no-cache-dir -r requirements.txt
# FastAPI + uvicorn (not in base requirements, add below)
RUN pip install --prefix=/install --no-cache-dir fastapi>=0.111.0 uvicorn[standard]>=0.29.0

FROM python:3.11-slim AS runtime
WORKDIR /app
COPY --from=builder /install /usr/local
RUN useradd -m -u 1001 appuser
COPY src/ ./src/
RUN mkdir -p ./chroma_db ./data ./workspace && chown -R appuser:appuser /app
USER appuser
EXPOSE 8001
ENV PYTHONUNBUFFERED=1 PYTHONDONTWRITEBYTECODE=1 PYTHONPATH=/app/src
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8001/health')"
ENTRYPOINT ["uvicorn", "agents.investigator_service:app", "--host", "0.0.0.0", "--port", "8001", "--workers", "1"]
