# Azure OpenAI
AZURE_OPENAI_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"
AZURE_OPENAI_API_KEY="your_api_key_here"
AZURE_OPENAI_DEPLOYMENT="gpt-4o"
AZURE_OPENAI_API_VERSION="2024-08-01-preview"

# Azure DevOps
AZURE_DEVOPS_ORG="https://dev.azure.com/your-org"
AZURE_DEVOPS_PROJECT="YourProject"
AZURE_DEVOPS_REPO="your-csharp-repo"
AZURE_DEVOPS_PAT="your_personal_access_token"

# Azure Blob Storage (exception CSV files)
AZURE_BLOB_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=<ACCOUNT>;AccountKey=<KEY>;EndpointSuffix=core.windows.net"
AZURE_BLOB_CONTAINER="exceptions"

# MS Teams Integration
TEAMS_WEBHOOK_URL=""

# Agent Settings
MAX_ATTEMPTS=3
CONFIDENCE_THRESHOLD=0.6
POLLING_INTERVAL_SECONDS=300
ERROR_FREQUENCY_THRESHOLD=3

# Review & Escalation (Stage 3)
MAX_REVIEW_POLLS=20
REVIEW_POLL_INTERVAL_SECONDS=30

# LangSmith Tracing (optional)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT="Autonomous-Multi-Agent-System"
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Stage 5: RAG Memory & Persistence
CHROMA_DB_PATH=./chroma_db
RAG_COLLECTION_NAME=workflow_history
RAG_TOP_K=3
SQLITE_DB_PATH=./data/workflows.db

# Local Settings
WORKING_DIR=./workspace
